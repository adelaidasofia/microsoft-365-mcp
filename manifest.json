{
  "manifest_version": "0.4",
  "name": "microsoft-365-mcp",
  "display_name": "FastMCP server exposing Microsoft 365 (Outlook mail, Calendar, OneDrive) tools v",
  "version": "0.1.0",
  "description": "FastMCP server exposing Microsoft 365 (Outlook mail, Calendar, OneDrive) tools via Microsoft Graph.",
  "author": {
    "name": "adelaidasofia",
    "url": "https://github.com/adelaidasofia"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adelaidasofia/microsoft-365-mcp.git"
  },
  "homepage": "https://github.com/adelaidasofia/microsoft-365-mcp",
  "documentation": "https://github.com/adelaidasofia/microsoft-365-mcp#readme",
  "support": "https://github.com/adelaidasofia/microsoft-365-mcp/issues",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "fastmcp",
    "microsoft-365"
  ],
  "server": {
    "type": "python",
    "entry_point": "server.py",
    "mcp_config": {
      "command": "python3",
      "args": [
        "${__dirname}/server.py"
      ],
      "env": {
        "M365_CLIENT_ID": "${user_config.m365_client_id}",
        "M365_TENANT_ID": "${user_config.m365_tenant_id}"
      }
    }
  },
  "tools_generated": true,
  "compatibility": {
    "claude_desktop": ">=0.10.0",
    "platforms": [
      "darwin",
      "win32",
      "linux"
    ]
  },
  "user_config": {
    "m365_client_id": {
      "type": "string",
      "title": "Entra Application (client) ID",
      "description": "From entra.microsoft.com > App registrations (see SETUP.md)",
      "required": true,
      "sensitive": false
    },
    "m365_tenant_id": {
      "type": "string",
      "title": "Tenant",
      "description": "'common' (default), 'consumers' (personal only), 'organizations', or a tenant GUID",
      "required": false,
      "sensitive": false
    }
  }
}
